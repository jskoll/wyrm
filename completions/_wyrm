#compdef wyrm
# Zsh completion for wyrm.
#
# Install: place this file (named exactly "_wyrm") on your $fpath, e.g.
#   fpath+=(/path/to/this/directory)
#   autoload -U compinit && compinit
# `brew install jskoll/tap/wyrm` installs it automatically.
#
# Dynamic completions shell out to wyrm itself, reusing its own config
# discovery and tmux session listing rather than reimplementing them here:
#   -config  -> `wyrm -list-configs`       (local + shared config file paths)
#   -format  -> static: table json toml names
#   bare arg -> `wyrm -list -format names` (running session names, for
#                `wyrm <name>` — see the wyrm(1) usage for what that does)

_wyrm() {
    _arguments \
        '-config[config file path]:config file:->configs' \
        '-kill[kill the session (runs on_project_exit)]' \
        '-pick[fuzzy-pick a running session to attach to]' \
        '-save[save the running session layout as a config for this folder]' \
        '-version[print version and exit]' \
        '-migrate-config[move the local config into the shared config directory]' \
        '-validate[check the effective config without building a session]' \
        '-list[list running tmux sessions non-interactively]' \
        '-format[output format for -list]:format:(table json toml names)' \
        '-edit[open the resolved config in $EDITOR]' \
        '-list-configs[list candidate config file paths]' \
        '1:session name:->sessions'

    case "$state" in
        configs)
            local -a configs
            configs=(${(f)"$(wyrm -list-configs 2>/dev/null)"})
            _describe 'config file' configs
            ;;
        sessions)
            local -a sessions
            sessions=(${(f)"$(wyrm -list -format names 2>/dev/null)"})
            _describe 'running session' sessions
            ;;
    esac
}

_wyrm "$@"
