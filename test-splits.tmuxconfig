[session]
name = "test-splits"
root = "."

[[windows]]
name = "test"

  [[windows.splits]]
  type = "horizontal"
  size = 60
  command = "echo 'pane 0'"

    [[windows.splits.children]]
    type = "v"
    command = "echo 'pane 1'"

    [[windows.splits.children]]
    type = "vertical"
    command = "echo 'pane 2'"
